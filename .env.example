SPRING_PROFILES_ACTIVE=prod
PORT=8080

# ===== Database =====
DB_URL=jdbc:postgresql://localhost:5432/raktakk_db
# DB_URL=jdbc:postgresql://postgres:LYVbuDgxRmCOkFHEYhCPYlpaDrQsdaJU@postgres.railway.internal:5432/railway

DB_USERNAME=postgresql
# DB_PASSWORD=postgres
DB_PASSWORD=LYVbuDgxRmCOkFHEYhCPYlpaDrQsdaJU


# ===== JWT Configuration =====
JWT_SECRET=<long-random-secret-at-least-32-chars>
JWT_REFRESH_SECRET=<long-random-refresh-secret-at-least-32-chars>
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=1209600000

REFRESH_COOKIE_NAME=raktakk_refresh_token
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAME_SITE=Lax

REQUIRE_HTTPS=true
SECURITY_CSP=default-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self';

CORS_ALLOWED_ORIGINS=https://<your-netlify-site>.netlify.app
OAUTH2_SUCCESS_REDIRECT_URI=https://<your-netlify-site>.netlify.app/oauth2/success

# ===== UnitechPay =====
# Clé API fournie par UnitechPay (test ou prod selon l'environnement)
UNITECH_API_KEY=
# URL locale ou publique pour les callbacks webhooks
UNITECH_CALLBACK_BASE=http://localhost:8090

# ===== Email Configuration (Gmail SMTP) =====
# For Gmail: Use Google App Password (NOT your regular Gmail password)
# 1. Enable 2FA on your Google Account
# 2. Go to myaccount.google.com/apppasswords
# 3. Select Mail and Windows Computer
# 4. Copy the generated password (format: xxxx xxxx xxxx xxxx)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<your-email@gmail.com>
MAIL_PASSWORD=<google-app-password>
MAIL_FROM=support@raktakk.com
MAIL_ADMIN=admin@raktakk.com

# ===== OAuth2 (Google) =====
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
