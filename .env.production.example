# Raktakk Backend - Environment Variables for Render Production
# TEMPLATE - DO NOT COMMIT ACTUAL VALUES TO GIT
# Copy values to Render UI or use a private environment file ignored by Git.

SPRING_PROFILES_ACTIVE=prod
PORT=8080

# ===== DATABASE =====
SPRING_DATASOURCE_URL=jdbc:postgresql://<render-postgres-host>:5432/<database>
SPRING_DATASOURCE_USERNAME=<database-user>
SPRING_DATASOURCE_PASSWORD=<database-password>


# ===== JWT Security (CHANGE THESE IN PRODUCTION) =====
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_A_BASE64_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_TO_A_BASE64_SECRET
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=1209600000

# ===== REFRESH TOKEN COOKIE =====
REFRESH_COOKIE_NAME=raktakk_refresh_token
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAME_SITE=Strict

# ===== SECURITY =====
REQUIRE_HTTPS=true
SECURITY_CSP=default-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self';

# ===== CORS - Frontend Domain (Netlify) =====
CORS_ALLOWED_ORIGINS=https://your-raktakk-site.netlify.app,https://your-custom-domain.com

# ===== EMAIL/SMTP Configuration =====
# Use SendGrid, AWS SES, or Gmail App Password for production
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD_16_CHARS
MAIL_FROM=support@raktakk.com
MAIL_ADMIN=admin@raktakk.com

# ===== OAuth2 (Google) =====
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ===== OAuth2 Redirect =====
OAUTH2_SUCCESS_REDIRECT_URI=https://your-raktakk-site.netlify.app/oauth2/success

# ===== Third-Party APIs =====
UNITECH_API_BASE=https://api.unitech.sn/api.php
UNITECH_API_KEY=YOUR_UNITECH_API_KEY
UNITECH_CALLBACK_BASE=https://your-backend.onrender.com
